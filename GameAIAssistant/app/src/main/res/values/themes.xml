<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LookGm" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- 基础色彩 -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_primary_dark</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <!-- 暗色背景 -->
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>

        <!-- 状态栏/导航栏：暗底亮字 -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_nav</item>
        <item name="android:navigationBarDividerColor">@color/divider</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- 全屏暗色 -->
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- 文字 -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Material 组件暗色覆盖 -->
        <item name="colorControlNormal">@color/text_secondary</item>
        <item name="colorControlActivated">@color/accent_primary</item>
        <item name="colorControlHighlight">@color/accent_bg</item>

        <!-- 底部导航 -->
        <item name="bottomNavigationStyle">@style/BottomNav</item>
    </style>

    <!-- 底部导航 — 电竞风 -->
    <style name="BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_nav</item>
        <item name="itemIconTint">@color/nav_selector</item>
        <item name="itemTextColor">@color/nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">8dp</item>
    </style>
</resources>
