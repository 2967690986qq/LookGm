<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingVertical="6dp">

    <!-- AI 头像 -->
    <TextView
        android:id="@+id/tv_avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp"
        android:gravity="center"
        android:text="🤖"
        android:textSize="18sp"
        android:background="@drawable/bg_avatar_ai" />

    <!-- AI 消息靠左，气泡自适应宽度，最大占屏幕 80% -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="40dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="280dp"
            android:padding="12dp"
            android:background="@drawable/bg_chat_bubble_ai"
            android:textColor="#E8ECF1"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp" />

        <!-- 流式打字指示点 -->
        <TextView
            android:id="@+id/tv_streaming_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            android:background="@drawable/bg_streaming_dot" />
    </LinearLayout>

</LinearLayout>
