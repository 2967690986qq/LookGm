<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="模型名称"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:layout_marginBottom="5dp" />

    <EditText
        android:id="@+id/et_dialog_model_name"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input"
        android:hint="如 gpt-4o, deepseek-chat"
        android:inputType="text"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="14sp"
        android:maxLines="1" />

    <TextView
        android:id="@+id/tv_classify_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/accent_primary"
        android:textSize="11sp"
        android:visibility="gone" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="显示标签（可选）"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="5dp" />

    <EditText
        android:id="@+id/et_dialog_label"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input"
        android:hint="如 GPT-4o (对话用)"
        android:inputType="text"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="14sp"
        android:maxLines="1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="用途"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="5dp" />

    <Spinner
        android:id="@+id/spinner_used_for"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

</LinearLayout>
