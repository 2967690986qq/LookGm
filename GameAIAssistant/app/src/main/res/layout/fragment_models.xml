<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 页头 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="模型配置"
            android:textColor="@color/accent_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="绑定供应商，每个供应商可添加多个模型"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="18dp" />

        <!-- 已配置徽章 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_configured_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/bg_primary"
                android:background="@drawable/bg_chip_selected"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:visibility="gone"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← 左右滑动选择供应商 →"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- ===== 供应商横向滑动 ===== -->
        <HorizontalScrollView
            android:id="@+id/hs_provider_chips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fadingEdgeLength="40dp"
            android:requiresFadingEdge="horizontal"
            android:overScrollMode="always"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/layout_provider_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="18dp" />

        <!-- ===== 当前供应商配置卡片 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_current_provider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- API Key -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/model_api_key"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_input"
                android:hint="@string/model_api_key_hint"
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:maxLines="1" />

            <!-- Base URL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/model_base_url"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/et_base_url"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_input"
                android:hint="接口地址，选择供应商后自动填充"
                android:inputType="textUri"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="13sp"
                android:maxLines="1" />

            <!-- 获取模型列表按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/btn_fetch_models"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_outline"
                    android:gravity="center"
                    android:text="@string/model_fetch"
                    android:textColor="@color/accent_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <TextView
                    android:id="@+id/btn_add_model"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_primary"
                    android:gravity="center"
                    android:text="+ 手动添加模型"
                    android:textColor="@color/bg_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 载指示器 -->
            <LinearLayout
                android:id="@+id/layout_fetch_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <ProgressBar
                    android:id="@+id/pb_fetch"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:indeterminateTint="@color/accent_primary" />

                <TextView
                    android:id="@+id/tv_fetch_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ===== 已绑定模型列表 ===== -->
            <TextView
                android:id="@+id/tv_bound_models_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已绑定的模型"
                android:textColor="@color/accent_gold"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/layout_bound_models"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- 空状态 -->
            <TextView
                android:id="@+id/tv_no_bound_models"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暂未绑定模型，点击下方按钮获取或手动添加"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- ===== 可用模型列表（点击添加到绑定）===== -->
        <TextView
            android:id="@+id/tv_model_section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="可用模型（点击添加）"
            android:textColor="@color/accent_purple"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layout_model_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/btn_test_model"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_outline"
                android:gravity="center"
                android:text="@string/model_test"
                android:textColor="@color/accent_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_save_config"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_btn_primary"
                android:gravity="center"
                android:text="@string/model_save"
                android:textColor="@color/bg_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_model_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- ===== 已绑定的供应商概览 ===== -->
        <TextView
            android:id="@+id/tv_configured_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已绑定的供应商"
            android:textColor="@color/accent_gold"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:id="@+id/layout_configured_providers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tv_no_configured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="尚未绑定任何供应商，请配置并保存"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="28dp" />

    </LinearLayout>
</ScrollView>
