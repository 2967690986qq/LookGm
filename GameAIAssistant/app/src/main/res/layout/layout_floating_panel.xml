<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="170dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_floating_panel"
    android:elevation="16dp"
    android:padding="8dp">

    <!-- 标题栏：分路名 + 收起按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tv_lane_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="选择分路"
            android:textColor="@color/accent_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_collapse"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="#8790A5"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 横向分路选择（紧凑） -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/lane_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/lane_top"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginEnd="5dp"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="对抗路"
                android:textColor="#E8ECF1"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_normal"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/lane_jungle"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginEnd="5dp"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="打野"
                android:textColor="#E8ECF1"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_normal"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/lane_mid"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginEnd="5dp"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="中路"
                android:textColor="#E8ECF1"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_normal"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/lane_adc"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginEnd="5dp"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="发育路"
                android:textColor="#E8ECF1"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_normal"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/lane_support"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="游走"
                android:textColor="#E8ECF1"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_normal"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 对局信息行 -->
    <LinearLayout
        android:id="@+id/layout_match_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <TextView android:id="@+id/tv_hero_name"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="英雄" android:textColor="#E8ECF1" android:textSize="11sp" android:textStyle="bold" />
        <TextView android:id="@+id/tv_current_score"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="--" android:textColor="@color/accent_primary" android:textSize="11sp" android:textStyle="bold" />
    </LinearLayout>

    <!-- AI 实时分析卡片 -->
    <LinearLayout
        android:id="@+id/card_ai_analysis"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel_item"
        android:padding="6dp"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <TextView android:id="@+id/tv_ai_analysis"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="AI 分析中..." android:textColor="#E8ECF1" android:textSize="10sp"
            android:lineSpacingExtra="2dp" android:maxLines="3" android:ellipsize="end" />
    </LinearLayout>

    <!-- 语音对话区域 -->
    <LinearLayout
        android:id="@+id/card_voice_conversation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel_item"
        android:padding="5dp"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView android:id="@+id/tv_conv_title"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="语音对话" android:textColor="@color/accent_primary"
                android:textSize="10sp" android:textStyle="bold" />

            <TextView android:id="@+id/btn_end_voice"
                android:layout_width="wrap_content" android:layout_height="18dp"
                android:gravity="center" android:text="结束" android:textColor="@color/status_error"
                android:textSize="9sp" android:paddingStart="6dp" android:paddingEnd="6dp"
                android:background="@color/bg_card" android:clickable="true" android:focusable="true" />
        </LinearLayout>

        <ScrollView android:id="@+id/scroll_conv"
            android:layout_width="match_parent" android:layout_height="70dp"
            android:scrollbars="vertical" android:fadeScrollbars="false"
            android:background="#337C3AED" android:padding="4dp">

            <LinearLayout android:id="@+id/layout_conv_messages"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <TextView android:id="@+id/tv_voice_state"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="点击麦克风开始对话" android:textColor="#8790A5"
            android:textSize="9sp" android:gravity="center"
            android:paddingTop="4dp" android:paddingBottom="2dp" />
    </LinearLayout>

    <!-- 分路任务区域 -->
    <LinearLayout android:id="@+id/layout_lane_tasks"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:id="@+id/tv_task_title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="任务指引" android:textColor="@color/accent_gold"
            android:textSize="11sp" android:textStyle="bold"
            android:layout_marginBottom="5dp" />

        <ScrollView
            android:layout_width="match_parent" android:layout_height="140dp"
            android:scrollbars="vertical" android:fadeScrollbars="false">

            <LinearLayout android:id="@+id/layout_task_list"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:paddingTop="2dp" />
        </ScrollView>
    </LinearLayout>

    <!-- 收起按钮 -->
    <TextView android:id="@+id/btn_minimize"
        android:layout_width="match_parent" android:layout_height="28dp"
        android:layout_marginTop="6dp" android:gravity="center"
        android:text="收起面板" android:textColor="#8790A5"
        android:textSize="10sp" android:background="@drawable/bg_panel_item"
        android:clickable="true" android:focusable="true" />
</LinearLayout>
