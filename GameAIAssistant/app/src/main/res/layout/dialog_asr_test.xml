<?xml version="1.0" encoding="utf-8"?>
<!-- ASR 语音转文字测试浮动对话框 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC080C1A"
    android:clickable="true">

    <!-- 浮动卡片容器 -->
    <LinearLayout
        android:id="@+id/card_root"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_asr_test_card"
        android:padding="20dp"
        android:elevation="16dp">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🎤 语音转文字测试"
                android:textColor="@color/accent_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="✕"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:background="@drawable/bg_chip_normal"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 状态提示条 -->
        <LinearLayout
            android:id="@+id/layout_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:background="@drawable/bg_input"
            android:layout_marginBottom="14dp">

            <View
                android:id="@+id/dot_status"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_status_dot" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="就绪 — 长按按钮开始录音"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- 加载动画 -->
            <ProgressBar
                android:id="@+id/pb_loading"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:indeterminateTint="@color/accent_primary"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 文本展示区 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="识别结果将在这里显示..."
                android:textColor="@color/text_hint"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />
        </ScrollView>

        <!-- 录音按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- 清空按钮 -->
            <TextView
                android:id="@+id/btn_clear"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_chip_normal"
                android:gravity="center"
                android:text="🗑"
                android:textSize="20sp"
                android:layout_marginEnd="16dp" />

            <!-- 按住录音按钮 -->
            <TextView
                android:id="@+id/btn_record"
                android:layout_width="160dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_primary"
                android:gravity="center"
                android:text="按住录音"
                android:textColor="@color/bg_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <!-- 重新录音按钮 -->
            <TextView
                android:id="@+id/btn_retry"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_chip_normal"
                android:gravity="center"
                android:text="🔄"
                android:textSize="20sp"
                android:layout_marginStart="16dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 提示文字 -->
        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="录音结束后自动上传识别，不支持实时边录边出字"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:gravity="center" />
    </LinearLayout>
</FrameLayout>
